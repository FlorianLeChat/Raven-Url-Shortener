#####################
# NextJS parameters #
#####################

## List of supported timezones: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Paris

## List of supported environments: dev, test, prod
NEXT_PUBLIC_ENV=development

## URL to the backend API server
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000/api

## CAPTCHA parameters
CAPTCHA_HMAC=secret_hmac_key
NEXT_PUBLIC_CAPTCHA_ENABLED=false

## Google Analytics parameters
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_TAG=G-XXXXXXXXXX
