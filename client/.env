######################
# Next.js parameters #
######################

## List of supported timezones: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Paris

## List of supported environments: development, production
NEXT_PUBLIC_ENV=development

## URL to the backend API server
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

## CAPTCHA parameters
# > CAPTCHA challenge is made locally using ALTCHA, an open-source, privacy-friendly CAPTCHA solution: https://altcha.org/
# > HMAC key is used to sign the CAPTCHA challenge and verify its integrity on the back-end. It should be a long, random string to ensure security.
NEXT_PUBLIC_CAPTCHA_ENABLED=false
CAPTCHA_HMAC=secret_hmac_key

## Analytics parameters
# > Data collection is made through umami, an open-source analytics solution: https://umami.is/
# > Enabling DNT (Do Not Track) user preference is recommended to respect user privacy: https://en.wikipedia.org/wiki/Do_Not_Track
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_PROJECT_ID=
NEXT_PUBLIC_ANALYTICS_RESPECT_DNT=true
ANALYTICS_SERVER_ENDPOINT=http://localhost:3000
