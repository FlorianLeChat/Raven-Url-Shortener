{
    "name": "florianlechat/raven-url-shortener",
    "type": "project",
    "homepage": "https://github.com/FlorianLeChat/Raven-Url-Shortener",
    "license": "MIT",
    "authors": [
        {
            "name": "Florian Trayon",
            "homepage": "https://github.com/FlorianLeChat",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/FlorianLeChat/Raven-Url-Shortener/issues"
    },
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "4.4.*",
        "doctrine/doctrine-bundle": "2.18.*",
        "doctrine/doctrine-migrations-bundle": "3.7.*",
        "doctrine/orm": "3.6.*",
        "nelmio/api-doc-bundle": "5.9.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "7.4.*",
        "symfony/http-client": "7.4.*",
        "symfony/lock": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/monolog-bundle": "4.0.*",
        "symfony/rate-limiter": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/validator": "7.4.*"
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "require-dev": {
        "phpmd/phpmd": "2.15.*",
        "phpunit/phpunit": "11.5.*",
        "phpstan/phpstan": "2.1.*",
        "phpstan/phpstan-symfony": "2.0.*",
        "phpstan/phpstan-doctrine": "2.0.*",
        "phpstan/extension-installer": "1.4.*",
        "symfony/process": "7.4.*",
        "symfony/browser-kit": "7.4.*",
        "symfony/debug-bundle": "7.4.*",
        "squizlabs/php_codesniffer": "4.0.*",
        "doctrine/doctrine-fixtures-bundle": "4.3.*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    }
}
